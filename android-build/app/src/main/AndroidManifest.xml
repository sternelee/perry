<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.perry.app">
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <!-- POST_NOTIFICATIONS: required at API 33+ (Android 13) before
         NotificationManager.notify() will display anything. The Kotlin
         side checks `ContextCompat.checkSelfPermission` and silently
         no-ops if not granted, so the lack of a runtime prompt here
         is fine for #94's "fire-and-forget" semantics; explicit
         permission UX lives in #95's onRegister flow. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <application android:allowBackup="true" android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name" android:theme="@android:style/Theme.Material.Light.NoActionBar">
        <activity android:name=".PerryActivity" android:exported="true"
            android:theme="@style/Theme.Perry.Splash"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- Routes notification taps to the JS callback registered via
             `notificationOnTap` (#97). exported=false because the action is
             internal — only PerryBridge fires this PendingIntent. -->
        <receiver android:name=".PerryNotificationReceiver" android:exported="false">
            <intent-filter>
                <action android:name="com.perry.app.NOTIFICATION_TAP" />
            </intent-filter>
        </receiver>
        <!-- Fires when an AlarmManager alarm scheduled via
             `notificationSchedule` (#96) goes off. Builds + posts the
             notification with the same channel and tap routing as
             `sendNotification`. -->
        <receiver android:name=".PerryScheduledNotificationReceiver" android:exported="false">
            <intent-filter>
                <action android:name="com.perry.app.SCHEDULED_FIRE" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
